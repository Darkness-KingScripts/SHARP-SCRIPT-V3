local function mesmoTime(character)
if not config.TeamCheck then
return false
end

local plr = Players:GetPlayerFromCharacter(character)

return plr and plr.Team == player.Team

end

local function bloqueado(part)
if not config.WallCheck then
return false
end

local origem = camera.CFrame.Position
local direcao = part.Position - origem

local params = RaycastParams.new()
params.FilterType = Enum.RaycastFilterType.Blacklist
params.FilterDescendantsInstances = {
player.Character
}

local resultado = workspace:Raycast(origem, direcao, params)

return resultado and not resultado.Instance:IsDescendantOf(part.Parent)

end

local function acharPlayer()
local alvo
local menor = config.FOVSize / 2

local centro = Vector2.new(
camera.ViewportSize.X / 2,
camera.ViewportSize.Y / 2
)

for _,plr in pairs(Players:GetPlayers()) do

if plr ~= player
and plr.Character
and plr.Character.Parent
and plr.Character:FindFirstChild("Head")
and plr.Character:FindFirstChild("Humanoid") then

local humanoid = plr.Character.Humanoid

if humanoid.Health <= 0 then
continue
end

local head = plr.Character:FindFirstChild("Head")

if not mesmoTime(plr.Character)
and not bloqueado(head) then

local pos, visivel = camera:WorldToViewportPoint(head.Position)

if visivel then
local distancia = (
Vector2.new(pos.X,pos.Y) - centro
).Magnitude

if distancia < menor then
menor = distancia
alvo = head
end

end

end

end

end

return alvo

end

RunService.RenderStepped:Connect(function()
if config.AimAssist then

local alvo = acharPlayer()

if alvo then
local mira = CFrame.lookAt(
camera.CFrame.Position,
alvo.Position
)

camera.CFrame = camera.CFrame:Lerp(
mira,
1.00
)

end

end

end)
